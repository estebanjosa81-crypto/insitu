# =============================================================================
# uni-eval-front — Variables de entorno
# =============================================================================
# Copia este archivo como .env y completa los valores reales.
# En Dokploy configura estas variables en: Project → Environment Variables
#
# ⚠️  IMPORTANTE — Variables NEXT_PUBLIC_*
# Estas variables se EMBEBEN en el bundle de Next.js durante el BUILD.
# Si cambias NEXT_PUBLIC_API_URL debes reconstruir la imagen Docker.
# Configúralas como Build Args en Dokploy además de como env vars.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# API BACKEND
# -----------------------------------------------------------------------------

# URL pública del backend accesible desde el navegador del usuario
# Debe apuntar al dominio público del backend (no al contenedor interno)
NEXT_PUBLIC_API_URL=https://api.tudominio.com/api/v1

# Timeout de las peticiones HTTP en milisegundos
NEXT_PUBLIC_API_TIMEOUT=30000

# Número de reintentos automáticos ante fallos de red
NEXT_PUBLIC_RETRY_ATTEMPTS=3

# Delay entre reintentos en milisegundos
NEXT_PUBLIC_RETRY_DELAY=1000
