DB_NAME=app

# --- DB local métricas (mismo contenedor MySQL) ---
DATABASE_URL_METRICAS=mysql://root:CambiarPorContraseñaSegura@mysql:3306/app_metricas

# --- DBs externas sigedin (solo lectura) ---
DATABASE_URL_AUTH=mysql://sysdevops:cQ%2F4x88%2F@185.236.182.88:3306/sigedin_seguridad
DATABASE_URL_USER=mysql://sysdevops:cQ%2F4x88%2F@185.236.182.88:3306/sigedin_ies

# --- JWT ---
# ⚠ Cambiar por un valor aleatorio fuerte (mínimo 32 chars)
JWT_SECRET=CambiarPorUnSecreto32CharsMinimo!!
JWT_EXPIRES_IN=8h

# --- CORS ---
ALLOWED_ORIGINS=https://eduportal.cloud,https://www.eduportal.cloud,http://161.97.169.196:3000

# --- URLs públicas del backend ---
API_BASE_URL=https://api.eduportal.cloud/api/v1
