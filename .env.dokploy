# --- IA / Ollama (contenedor interno) ---
OLLAMA_HOST=http://ollama:11434
LLM_MODEL=llama3.1:8b

# --- Frontend Next.js (se embebe en el build — requiere rebuild si cambia) ---
NEXT_PUBLIC_API_URL=https://api.eduportal.cloud/api/v1
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_RETRY_ATTEMPTS=3
NEXT_PUBLIC_RETRY_DELAY=1000

# --- Logs / Debug ---
LOG_LEVEL=INFO
VALIDATION_DEBUG=false
SKIP_DB_CHECK=false
