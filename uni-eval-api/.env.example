# =============================================================================
# uni-eval-api — Variables de entorno
# =============================================================================
# Copia este archivo como .env y completa los valores reales.
# En Dokploy configura estas variables en: Project → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=5000

# -----------------------------------------------------------------------------
# BASES DE DATOS (Prisma)
# -----------------------------------------------------------------------------

# Base de datos local — contenedor MySQL del docker-compose.dokploy.yml
# Formato: mysql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=mysql://root:CHANGE_ME_DB_PASSWORD@mysql:3306/uni_eval

# Base de datos sigedin_seguridad (autenticación externa)
DATABASE_URL_AUTH=mysql://usuario:contraseña@host-externo:3306/sigedin_seguridad

# Base de datos sigedin_ies (datos académicos externos)
DATABASE_URL_USER=mysql://usuario:contraseña@host-externo:3306/sigedin_ies

# Base de datos de métricas (opcional)
DATABASE_URL_METRIC=mysql://usuario:contraseña@host-externo:3306/db_metricas

# Variables de conveniencia para el contenedor MySQL local
DB_ROOT_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=uni_eval

# -----------------------------------------------------------------------------
# JWT / AUTENTICACIÓN
# -----------------------------------------------------------------------------

# Mínimo 32 caracteres aleatorios. Genera uno con: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# Tiempo de expiración del token (ej: 8h, 1d, 7d)
JWT_EXPIRES_IN=8h

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Orígenes permitidos separados por coma (sin espacios)
# Ejemplo: https://app.tudominio.com,https://admin.tudominio.com
ALLOWED_ORIGINS=https://tu-frontend.tudominio.com

# -----------------------------------------------------------------------------
# SWAGGER / URL DEL API
# -----------------------------------------------------------------------------

# URL pública del backend (usada en la documentación Swagger)
API_BASE_URL=https://api.tudominio.com/api/v1
API_SWAGGER_URL=https://api.tudominio.com/api/v1

# -----------------------------------------------------------------------------
# INTELIGENCIA ARTIFICIAL (Ollama)
# -----------------------------------------------------------------------------

# URL del contenedor Ollama (interna del compose)
OLLAMA_HOST=http://ollama:11434

# Modelo a usar. Opciones comunes:
#   llama3.1:8b-instruct-q4_K_M  (recomendado, ~5GB)
#   llama3.2:3b-instruct-q4_K_M  (más ligero, ~2GB)
#   mistral:7b-instruct-q4_K_M
LLM_MODEL=llama3.1:8b-instruct-q4_K_M

# -----------------------------------------------------------------------------
# DEBUG
# -----------------------------------------------------------------------------

# Activar logs de validación (true solo en desarrollo)
VALIDATION_DEBUG=false
