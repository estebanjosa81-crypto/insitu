// =============================================================================
// DB AUTH — sigedin_seguridad (solo lectura, NO migrations)
// Schema mantenido manualmente.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../../src/prisma/generated/auth"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_AUTH")
}

model datalogin {
  user_id       Int     @id @default(autoincrement())
  user_username String? @db.VarChar(100)
  user_password String? @db.VarChar(255)
  user_idrole   Int?
  user_statusid Int?
  role_name     String? @db.VarChar(255)
}
